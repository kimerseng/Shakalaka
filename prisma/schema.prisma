generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Movie {
  title     String
  duration  String
  type      String
  subtitle  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  poster    String?
  id        Int      @id @default(autoincrement())
  year      Int?
}

model HeroContent {
  id         String   @id @default("hero-main")
  title      String
  subtitle   String
  imageUrl   String
  buttonText String
  updatedAt  DateTime @updatedAt
}

model CustomSection {
  id            String   @id @default(cuid())
  title         String
  content       String
  imageUrl      String
  imagePosition String
  page          String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
