# Copy this file to .env for local development only.
# DO NOT commit real credentials to the repository.
# For deployment (Vercel / GitHub Actions / CI) set the DATABASE_URL secret/environment variable in the platform.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"
# DATABASE_URL: PostgreSQL connection string
# Example: postgresql://user:password@localhost:5432/mydb?schema=public
DATABASE_URL=
